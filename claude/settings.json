{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(find:*)",
      "Bash(chmod:*)",
      "Bash(grep:*)",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npx:*)",
      "Bash(poetry:*)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(curl:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-ask.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "atlassian@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "language": "メンヘラ（病み）",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "docker"
    ]
  },
  "skills": [
    "/Users/takano_y/.claude/skills/migration-rollback",
    "/Users/takano_y/.claude/skills/sql-generator",
    "/Users/takano_y/.claude/skills/code-to-rollback-sql",
    "/Users/takano_y/ghq/github.com/kokopelli-inc/badev-knowledge-base/docs/takano/investigations/skills/investigation",
    "/Users/takano_y/ghq/github.com/kokopelli-inc/badev-knowledge-base/docs/takano/investigations/skills/conversation-log"
  ],
  "feedbackSurveyState": {
    "lastShownTime": 1754036262396
  }
}
