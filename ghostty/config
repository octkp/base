# フォント設定（複数指定でフォールバック）
font-family = JetBrainsMono Nerd Font
font-family = Hiragino Sans
font-size = 16
adjust-cell-height = -2

# テーマ
theme = IR Black

# フォントの合成（無理やりな太字化など）を禁止して安定させる
font-synthetic-style = false

# 文字幅の計算を厳密にする（日本語のズレ防止）
adjust-cell-width = 0

# ウィンドウ設定
window-padding-x = 10
window-padding-y = 10
window-width = 100
window-height = 28

# タブバー設定
window-show-tab-bar = always

# macOS固有設定
macos-option-as-alt = true
